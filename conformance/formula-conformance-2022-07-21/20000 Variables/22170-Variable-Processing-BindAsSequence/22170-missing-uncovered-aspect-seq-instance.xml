<xbrl 
xmlns="http://www.xbrl.org/2003/instance" 
xmlns:concept="http://xbrl.org/formula/conformance/example" 
xmlns:link="http://www.xbrl.org/2003/linkbase" 
xmlns:xlink="http://www.w3.org/1999/xlink" 
xmlns:iso4217="http://www.xbrl.org/2003/iso4217" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xmlns:xbrldi="http://xbrl.org/2006/xbrldi"
xsi:schemaLocation="http://xbrl.org/2006/xbrldi http://www.xbrl.org/2006/xbrldi-2006.xsd"
>
  
  <link:schemaRef 
    xlink:type="simple" 
    xlink:href="22170-sequence-dim-tests.xsd"/>

  <link:linkbaseRef 
    xlink:type="simple" 
    xlink:arcrole="http://www.w3.org/1999/xlink/properties/linkbase" 
    xlink:href="22170-missing-uncovered-aspect-seq-formula.xml"/>
  
  <context id="context-earth">
    <entity>
      <identifier scheme="http://xbrl.org/entity/identification/scheme">01</identifier>
      <segment>
        <xbrldi:explicitMember dimension="concept:MoonDim">concept:Earth</xbrldi:explicitMember>
      </segment>
    </entity>
    <period>
      <instant>2007-12-31</instant>
    </period>
  </context>

  <context id="context-none">
    <entity>
      <identifier scheme="http://xbrl.org/entity/identification/scheme">01</identifier>
    </entity>
    <period>
      <instant>2007-12-31</instant>
    </period>
  </context>


  <unit id="u-moon-count">
    <measure>pure</measure>
  </unit>
  
    <concept:NonDimensionalItem contextRef="context-earth" unitRef="u-moon-count" decimals="0">1</concept:NonDimensionalItem>
    <!-- Doesn't have value for dimension, thus is not aspect matched. -->
    <concept:NonDimensionalItem contextRef="context-none" unitRef="u-moon-count" decimals="0">100</concept:NonDimensionalItem>

</xbrl>



