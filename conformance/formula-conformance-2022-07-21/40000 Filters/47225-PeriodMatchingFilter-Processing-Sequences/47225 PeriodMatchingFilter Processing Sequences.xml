  <number>47225</number>
  <name>Period matching filter test</name>
  <description>
    Tests of period matching filter.
    Assumes that non-sequential matching works as these tests only check sequence behaviour.
  </description>
  <reference specification="MATCH-FILTER" id="sec-period-matching-filter"/>

  <variation id="V-101">
  	<name>period matching filter</name>
    <description>Two instant concepts, one duration concept. Each single item should match an item the sequence of all three items.</description>
    <data>
      <schema>47225-concepts.xsd</schema>
      <linkbase>47225-periodMatching-formula-V101.xml</linkbase>
      <instance readMeFirst="true">47225-periodMatching-instance-V101.xml</instance>
    </data>
    <result>
      <instance>47225-periodMatching-result-V101.xml</instance>
    </result>
  </variation>  

  <variation id="V-102">
    <name>period matching filter</name>
    <description>Two instant concepts, one duration concept. Two of the three single items should match an item in the sequence of two items/</description>
    <data>
      <schema>47225-concepts.xsd</schema>
      <linkbase>47225-periodMatching-formula-V102.xml</linkbase>
      <instance readMeFirst="true">47225-periodMatching-instance-V102.xml</instance>
    </data>
    <result>
      <instance>47225-periodMatching-result-V102.xml</instance>
    </result>
  </variation>  
  
  <variation id="V-103">
    <name>period matching filter</name>
    <description>Two instant concepts, one duration concept. Same as above but complemented result should give the single non-matching item.</description>
    <data>
      <schema>47225-concepts.xsd</schema>
      <linkbase>47225-periodMatching-formula-V103.xml</linkbase>
      <instance readMeFirst="true">47225-periodMatching-instance-V103.xml</instance>
    </data>
    <result>
      <instance>47225-periodMatching-result-V103.xml</instance>
    </result>
  </variation>  
  
