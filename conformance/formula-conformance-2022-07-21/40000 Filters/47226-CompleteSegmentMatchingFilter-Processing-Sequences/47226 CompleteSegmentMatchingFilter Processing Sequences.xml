  <number>47226</number>
  <name>Complete Segment matching filter test</name>
  <description>
    Tests of complete segment matching filter.
    Assumes that non-sequential matching works as these tests only check sequence behaviour.
  </description>
  <reference specification="MATCH-FILTER" id="sec-complete-segment-matching-filter"/>

  <variation id="V-101">
     <name>Source and target have same complete segment</name>
    <description>Matches each single source item agains sequence of all items - all should match - includes empty segment.
    </description>
    <data>
      <schema>47226-completeSegMatch-concepts.xsd</schema>
      <linkbase>47226-completeSegMatch-definition.xml</linkbase>
      <linkbase>47226-completeSegMatch-formula-V101.xml</linkbase>
      <instance readMeFirst="true">47226-completeSegMatch-instance-V101.xml</instance>
    </data>
    <result>
      <instance>47226-completeSegMatch-result-V101.xml</instance>
    </result>
  </variation>  

  <variation id="V-102">
    <name>Source and target have complex structure of elements included</name>
    <description>Source and target have complex structure of elements included</description>
    <data>
      <schema>47226-completeSegMatch-concepts.xsd</schema>
      <linkbase>47226-completeSegMatch-definition.xml</linkbase>
      <linkbase>47226-completeSegMatch-formula-V102.xml</linkbase>
      <instance readMeFirst="true">47226-completeSegMatch-instance-V102.xml</instance>
    </data>
    <result>
      <instance>47226-completeSegMatch-result-V102.xml</instance>
    </result>
  </variation>  

  <variation id="V-103">
    <name>Source and target have element attributes in different order</name>
        <description>Source and target have element attributes in different order, numerics equal but different syntax. (Deferred by commenting out, text with whitespaces around match (but not xml:space=&quot;preserve&quot;)).</description>
    <data>
      <schema>47226-completeSegMatch-concepts.xsd</schema>
      <linkbase>47226-completeSegMatch-definition.xml</linkbase>
      <linkbase>47226-completeSegMatch-formula-V103.xml</linkbase>
      <instance readMeFirst="true">47226-completeSegMatch-instance-V103.xml</instance>
    </data>
    <result>
      <instance>47226-completeSegMatch-result-V103.xml</instance>
    </result>
  </variation>  

</testcase>

