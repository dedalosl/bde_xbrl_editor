  <number>47208</number>
  <name>Segment dimension matching filter test</name>
  <description>
    Tests of segment dimension matching filter where matchAny='true'.
    Assumes that non-sequential matching works as these tests only check sequence behaviour.
  </description>
  <reference specification="MATCH-FILTER" id="sec-segment-dimension-matching-filter"/>

  <variation id="V-101">
    <name>Explicit dimensions are equal, they have same member</name>
    <description>Test individual items against sequence of all items, all facts match</description>
    <data>
      <schema>47208-segDimMatch-concepts.xsd</schema>
      <linkbase>47208-segDimMatch-definition.xml</linkbase>
      <linkbase>47208-segDimMatch-explDim1-formula-V101.xml</linkbase>
      <instance readMeFirst="true">47208-segDimMatch-instance-V101.xml</instance>
    </data>
    <result>
      <instance>47208-segDimMatch-result-V101.xml</instance>
    </result>
  </variation>  

  <variation id="V-102">
    <name>Explicit dimensions are equal, they have same member</name>
    <description>Test all items against sequence of items with explicit dimension member2</description>
    <data>
      <schema>47208-segDimMatch-concepts.xsd</schema>
      <linkbase>47208-segDimMatch-definition.xml</linkbase>
      <linkbase>47208-segDimMatch-explDim1-formula-V102.xml</linkbase>
