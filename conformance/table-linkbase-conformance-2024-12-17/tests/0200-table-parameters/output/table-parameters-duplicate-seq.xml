<?xml version="1.0" encoding="utf-8"?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
    <tableSet>
        <label>Table using table-parameter relationships to produce a table set</label>
        <table>
            <headers axis="y">
                <group>
                    <label>One row</label>
	                <header>
	                    <cell>
	                        <label>Label: concept = $conceptName</label>
	                        <constraint>
	                            <aspect>concept</aspect>
	                            <value>rend:m1</value>
	                        </constraint>
	                    </cell>
	                </header>
                </group>
            </headers>
            <headers axis="x">
                <group>
                    <label>One column</label>
	                <header>
	                    <cell>
	                        <label>Label: D = $dimMember</label>
	                        <constraint>
	                            <aspect>rend:D</aspect>
	                            <value>rend:d1</value>
	                        </constraint>
	                    </cell>
	                </header>
                </group>
            </headers>
            <cells axis="z">
                <cells axis="y">
                    <cells axis="x">
                        <cell/>
                    </cells>
                </cells>
            </cells>
        </table>
        <table>
            <headers axis="y">
                <group>
                    <label>One row</label>
	                <header>
	                    <cell>
	                        <label>Label: concept = $conceptName</label>
	                        <constraint>
	                            <aspect>concept</aspect>
	                            <value>rend:m1</value>
	                        </constraint>
	                    </cell>
	                </header>
                </group>
            </headers>
            <headers axis="x">
                <group>
                    <label>One column</label>
	                <header>
	                    <cell>
	                        <label>Label: D = $dimMember</label>
	                        <constraint>
	                            <aspect>rend:D</aspect>
	                            <value>rend:d1</value>
	                        </constraint>
	                    </cell>
	                </header>
                </group>
            </headers>
            <cells axis="z">
                <cells axis="y">
                    <cells axis="x">
                        <cell/>
                    </cells>
                </cells>
            </cells>
        </table>
    </tableSet>
</tableModel>