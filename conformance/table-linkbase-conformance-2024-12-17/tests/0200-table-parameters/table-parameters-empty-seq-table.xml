<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:reference="http://xbrl.org/2008/reference"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:variable="http://xbrl.org/2008/variable"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xbrldi="http://xbrl.org/2006/xbrldi"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2008/variable http://www.xbrl.org/2008/variable.xsd
                  http://xbrl.org/2008/filter/dimension http://www.xbrl.org/2008/dimension-filter.xsd
                  http://xbrl.org/2006/xbrldi http://www.xbrl.org/2006/xbrldi-2006.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table2"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#table2"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-parameter" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-parameter"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple"
                 xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

<!-- Table 2, a simple example of 2 rows of primaries by 2 columns containing 2 members of the same dimension -->
   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table2">
   
<!-- Parameters for the concept/dimension qnames. Note the Cartesian product will be empty as the second parameter is the empty sequence -->
      <variable:parameter xlink:type="resource" xlink:label="conceptName" name="conceptName" select="(QName('http://www.xbrl.org/table-examples', 'm1'), QName('http://www.xbrl.org/table-examples', 'm2'))"/>
      <variable:parameter xlink:type="resource" xlink:label="dimMember" name="dimMember" select="()"/>

<!-- Relationships connecting the table to the parameters -->
      <table:tableParameterArc xlink:arcrole="http://xbrl.org/arcrole/2014/table-parameter" name="conceptName" xlink:from="table2" xlink:to="conceptName" xlink:type="arc" />
      <table:tableParameterArc xlink:arcrole="http://xbrl.org/arcrole/2014/table-parameter" name="dimMember" xlink:from="table2" xlink:to="dimMember" xlink:type="arc" />

<!-- Declare table as a resource -->
      <table:table xlink:type="resource" xlink:label="table2" id="table2"/>
<!-- Create appropriate label for the table -->
      <label:label xlink:type="resource" xlink:label="label_table2" id="label_table2"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Table using table-parameter relationships to produce a table set</label:label>
<!-- Connect table resource to table label -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2"
               xlink:to="label_table2"/>

<!-- Declare X axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table2-x" id="table2-x"/>
<!-- Connect table to X axis -->
      <table:tableBreakdownArc xlink:type="arc"
                               xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="x"
                               xlink:from="table2"
                               xlink:to="table2-x"
                               order="4"/>
<!-- Create appropriate label for first breakdown on X axis -->
      <label:label xlink:type="resource" xlink:label="label_table2-x"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-x">One column</label:label>
<!-- Connect label to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-x"
               xlink:to="label_table2-x"/>

<!-- Find content for first column header on X axis by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table2-x.1" id="table2-x.1">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qnameExpression>$dimMember</formula:qnameExpression>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect first column header to X axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table2-x"
                              xlink:to="table2-x.1"
                              order="2"/>
<!-- Create appropriate label for first column and first row header on X axis (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table2-x.11" id="label_table2-x.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = $dimMember</label:label>
<!-- Connect first row header label on X axis to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-x.1"
               xlink:to="label_table2-x.11"/>


<!-- Declare Y axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table2-y" id="table2-y"/>
<!-- Connect table to Y axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="y"
                               xlink:from="table2"
                               xlink:to="table2-y"
                               order="6"/>
<!-- Create appropriate label for first breakdown on Y axis -->
      <label:label xlink:type="resource" xlink:label="label_table2-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-y">One row</label:label>
<!-- Connect label to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y"
               xlink:to="label_table2-y"/>

<!-- Find content for first column header on Y axis by stating the primary -->
      <table:ruleNode xlink:type="resource" xlink:label="table2-y.1" id="table2-y.1">
         <formula:concept>
            <formula:qnameExpression>$conceptName</formula:qnameExpression>
         </formula:concept>
      </table:ruleNode>
<!-- Connect first column header to Y axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table2-y"
                              xlink:to="table2-y.1"
                              order="2"/>
<!-- Create appropriate label for first column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table2-y.11" id="label_table2-y.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: concept = $conceptName</label:label>
<!-- Connect first column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y.1"
               xlink:to="label_table2-y.11"/>
   </gen:link>

</link:linkbase>