<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:reference="http://xbrl.org/2008/reference"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="
               http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
               http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
               http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
               http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
               http://xbrl.org/2008/filter/dimension http://www.xbrl.org/2008/dimension-filter.xsd
               http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table1"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#table1"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple"
                 xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
                 
   <gen:link xlink:type="extended"
             xlink:role="http://www.xbrl.org/table-examples/table1">
      <table:table xlink:type="resource" xlink:label="table1"
                   id="table1"/>
      <label:label xlink:type="resource" xlink:label="label_table11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table11">Breakdowns with and without constraints on an axis</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1"
               xlink:to="label_table11"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table1-x1" id="table1-x1" />
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table1"
                          xlink:to="table1-x1"
                          order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x1">Two columns (dimension D = d1, d2)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1"
               xlink:to="label_table1-x1"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x1.1" id="table1-x1.1">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qname>rend:d1</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table1-x1"
                              xlink:to="table1-x1.1"
                              order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.11" id="label_table1-x1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = d1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.1"
               xlink:to="label_table1-x1.11"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.12" id="label_table1-x1.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.1"
               xlink:to="label_table1-x1.12"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x1.2" id="table1-x1.2">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qname>rend:d2</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table1-x1"
                              xlink:to="table1-x1.2"
                              order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.21" id="label_table1-x1.21"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = d2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.2"
               xlink:to="label_table1-x1.21"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.22" id="label_table1-x1.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.2"
               xlink:to="label_table1-x1.22"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table1-x2" id="table1-x2" />
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table1"
                          xlink:to="table1-x2"
                          order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x2">Single column (no constraint)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2"
               xlink:to="label_table1-x2"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x2.1" id="table1-x2.1"/>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x2"
               xlink:to="table1-x2.1"
               order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x2.11">No constraint</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2.1"
               xlink:to="label_table1-x2.11"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table1-y" id="table1-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="y"
                               xlink:from="table1"
                               xlink:to="table1-y"
                               order="6"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-y">Two rows (primary items m1, m2)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y"
               xlink:to="label_table1-y"/>

      <table:ruleNode xlink:type="resource" xlink:label="table1-y.1" id="table1-y.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table1-y"
                              xlink:to="table1-y.1"
                              order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y.11" id="label_table1-y.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: m1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y.1"
               xlink:to="label_table1-y.11"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y.12" id="label_table1-y.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y.1"
               xlink:to="label_table1-y.12"/>

      <table:ruleNode xlink:type="resource" xlink:label="table1-y.2" id="table1-y.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table1-y"
                              xlink:to="table1-y.2"
                              order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y.21" id="label_table1-y.21"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y.2"
               xlink:to="label_table1-y.21"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y.22" id="label_table1-y.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y.2"
               xlink:to="label_table1-y.22"/>
   </gen:link>

</link:linkbase>