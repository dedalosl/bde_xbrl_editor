            <schema>table-examples.xsd</schema>
        </data>
        <result>
            <table>output/breakdown-without-nodes.xml</table>
        </result>
    </variation>

    <variation id="v-04">
        <name>Combine a breakdown with no nodes (and therefore no constraints) with another breakdown</name>
        <description>
          Table with a breakdown that has no nodes and combines it with another
          breakdown with nodes. This variation has no instance.
        </description>
        <reference specification="rendering-requirements" useCase="????"/>
        <data>
            <linkbase readMeFirst="true">combine-breakdown-without-nodes-table.xml</linkbase>
            <linkbase>table-examples-definition.xml</linkbase>
            <linkbase>table-examples-label.xml</linkbase>
            <schema>table-examples-roles.xsd</schema>
            <schema>table-examples.xsd</schema>
        </data>
        <result>
            <table>output/combine-breakdown-without-nodes-no-data.xml</table>
        </result>
    </variation>

    <variation id="v-04i">
        <name>Combine a breakdown with no nodes (and therefore no constraints) with another breakdown, with instance</name>
        <description>
          Table with a breakdown that has no nodes and combines it with another
          breakdown with nodes.
        </description>
        <reference specification="rendering-requirements" useCase="????"/>
        <data>
            <instance readMeFirst="true">combine-breakdown-without-nodes-instance.xml</instance>
            <linkbase>combine-breakdown-without-nodes-table.xml</linkbase>
            <linkbase>table-examples-definition.xml</linkbase>
            <linkbase>table-examples-label.xml</linkbase>
            <schema>table-examples-roles.xsd</schema>
            <schema>table-examples.xsd</schema>
        </data>
        <result>
            <table>output/combine-breakdown-without-nodes.xml</table>
        </result>
    </variation>
    
</testcase>