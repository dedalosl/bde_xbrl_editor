<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xmlns:xbrli="http://www.xbrl.org/2003/instance" xml:base="..">
  <tableSet>
    <label>Rule nodes with entity identifier rules</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (entity identifier = 01, 02)</label>
          <header>
            <cell>
              <label>01</label>
              <constraint>
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme">01</xbrli:identifier>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>02</label>
              <constraint>
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme">02</xbrli:identifier>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell/>
            <cell/>
          </cells>
          <cells axis="x">
            <cell/>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>