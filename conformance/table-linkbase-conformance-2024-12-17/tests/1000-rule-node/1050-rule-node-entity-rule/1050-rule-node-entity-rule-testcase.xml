<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet type="text/xsl" href="../../../infrastructure/test.xsl"?>
<testcase
  date="2011-09-16"
  name="1050-rule-node-entity-rule-testcase"
  xmlns="http://xbrl.org/2008/conformance"
  xmlns:xbrlte="http://xbrl.org/2014/table/error"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://xbrl.org/2008/conformance ../../../infrastructure/test.xsd">
    <creator>
        <name>Herm Fischer</name>
        <email>fischer@markv.com</email>
    </creator>
    <number>1050</number>
    <name>Rule Node Entity Rule Testcase</name>
    <description>Table linkbase test case using a rule node with an entity rule</description>

    <variation id="v-01">
        <name>Rule nodes with entity identifier rules</name>
        <description>
          Simple table with two rows (primary items m1, m2) and two columns
          (entity identifiers 01, 02). In this variation there is no instance.
        </description>
        <reference specification="rendering-requirements" useCase="????"/>
        <data>
            <linkbase readMeFirst="true">entity-identifier-table.xml</linkbase>
            <linkbase>table-examples-definition.xml</linkbase>
            <linkbase>table-examples-label.xml</linkbase>
            <schema>table-examples-roles.xsd</schema>
            <schema>table-examples.xsd</schema>
        </data>
        <result>
            <table>output/entity-identifier-no-data.xml</table>
        </result>
    </variation>
    
    <variation id="v-01i">
        <name>Rule nodes with entity identifier rules, with instance</name>
        <description>
          Simple table with two rows (primary items m1, m2) and two columns
          (entity identifiers 01, 02).
        </description>
        <reference specification="rendering-requirements" useCase="????"/>
        <data>
            <instance readMeFirst="true">entity-identifier-instance.xml</instance>
            <linkbase>entity-identifier-table.xml</linkbase>
            <linkbase>table-examples-definition.xml</linkbase>
            <linkbase>table-examples-label.xml</linkbase>
            <schema>table-examples-roles.xsd</schema>
            <schema>table-examples.xsd</schema>
        </data>
        <result>
            <table>output/entity-identifier.xml</table>
        </result>
    </variation>

    <variation id="v-02">
        <name>Simple Table with an incomplete entity identifier rule.</name>
        <description>Simple table with one x axis node for an incomplete entity identifier rule.</description>
        <reference specification="rendering-requirements" useCase="????"/>
        <data>
            <linkbase readMeFirst="true">incomplete-entity-identifier-rule-table.xml</linkbase>
            <linkbase>table-examples-definition.xml</linkbase>
            <linkbase>table-examples-label.xml</linkbase>
            <schema>table-examples-roles.xsd</schema>
            <schema>table-examples.xsd</schema>
        </data>
        <result>
           <error>xbrlte:incompleteAspectRule</error>
        </result>
    </variation>

</testcase>