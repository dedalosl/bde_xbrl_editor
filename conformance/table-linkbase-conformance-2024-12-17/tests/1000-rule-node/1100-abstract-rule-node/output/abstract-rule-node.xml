<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Table with an abstract rule node</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (dimensions E = e1, D = d1, d2)</label>
          <header>
            <cell span="2">
              <label>Label: E = e1</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
          </header>
          <header>
            <cell>
              <label>Label: D = d1</label>
              <label>1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: D = d2</label>
              <label>2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>abstract-rule-node-instance.xml#m1_E_e1_D_d1</fact>
            </cell>
            <cell>
              <fact>abstract-rule-node-instance.xml#m1_E_e1_D_d2</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>abstract-rule-node-instance.xml#m2_E_e1_D_d1</fact>
            </cell>
            <cell>
              <fact>abstract-rule-node-instance.xml#m2_E_e1_D_d2</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>