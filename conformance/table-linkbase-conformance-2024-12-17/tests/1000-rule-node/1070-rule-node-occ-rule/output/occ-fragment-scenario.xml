<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Rule nodes with occ scenario rules</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (occ scenario rules)</label>
          <header>
            <cell>
              <label>scenario element 1</label>
              <constraint>
                <aspect>scenario</aspect>
                <value>
                  <rend:scenarioElement1/>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>scenario element 2</label>
              <constraint>
                <aspect>scenario</aspect>
                <value>
                  <rend:scenarioElement2/>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>occ-fragment-scenario-instance.xml#m1_c_0</fact>
            </cell>
            <cell>
              <fact>occ-fragment-scenario-instance.xml#m1_c_1</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>occ-fragment-scenario-instance.xml#m2_c_0</fact>
            </cell>
            <cell>
              <fact>occ-fragment-scenario-instance.xml#m2_c_1</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>