<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <!--Entry point file: instance-simple-table.xml-->
  <tableSet>
    <!--TableSet linkbase file: table-linkbase-multiple-rules.xml, line 35-->
    <!--TableSet namespace: http://xbrl.org/2014/table-->
    <!--TableSet linkrole: http://www.xbrl.org/table-examples/table9-->
    <label>Table with two columns each with multiple dimension values</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <!--ruleNode: label table1-y.1, file table-linkbase-simple-table.xml, line 121-->
            <!--   aspect concept: rend:m1-->
            <cell>
              <label>Label: m1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-y.2, file table-linkbase-simple-table.xml, line 141-->
            <!--   aspect concept: rend:m2-->
            <cell>
              <label>Label: m2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (dimension [D, E] = [d1, e1], [d1, e2])</label>
          <header>
            <!--ruleNode: label table1-x.1, file table-linkbase-multiple-rules.xml, line 55-->
            <!--   aspect rend:D: rend:d1-->
            <!--   aspect rend:E: rend:e1-->
            <cell>
              <label>Label: D = d1, E = e1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-x.2, file table-linkbase-multiple-rules.xml, line 83-->
            <!--   aspect rend:D: rend:d1-->
            <!--   aspect rend:E: rend:e2-->
            <cell>
              <label>Label: D = d1, E = e2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell/>
            <cell/>
          </cells>
          <cells axis="x">
            <cell/>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>