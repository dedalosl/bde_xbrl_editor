<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Table with dual breakdowns with roll-up on the x-axis</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Three columns (dimension D = d0, d1, d2)</label>
          <header>
            <cell span="6">
              <label>Label: D</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value/>
              </constraint>
            </cell>
          </header>
          <header>
            <cell rollup="true" span="2"/>
            <cell span="2">
              <label>Label: D = d1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
            </cell>
            <cell span="2">
              <label>Label: D = d2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d2</value>
              </constraint>
            </cell>
          </header>
        </group>
        <group>
          <label>Two columns (dimension E = e1, e2)</label>
          <header>
            <cell>
              <label>Label: E = e1</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: E = e2</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: E = e1</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: E = e2</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: E = e1</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: E = e2</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell/>
            <cell/>
            <cell/>
            <cell/>
            <cell/>
            <cell/>
          </cells>
          <cells axis="x">
            <cell/>
            <cell/>
            <cell/>
            <cell/>
            <cell/>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>