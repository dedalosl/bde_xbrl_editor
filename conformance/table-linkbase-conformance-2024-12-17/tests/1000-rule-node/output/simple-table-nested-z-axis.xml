              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <!--ruleNode: label table8-y.2, file table-linkbase-simple-table-nested-z-axis.xml, line 195-->
            <!--   aspect concept: rend:m2-->
