<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table10" xlink:type="simple" xlink:href="table-examples-roles.xsd#table10"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code" xlink:type="simple" xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table10">

      <table:table xlink:type="resource" xlink:label="table10" id="table10"/>
      <label:label xlink:type="resource" xlink:label="label_table10" id="label_table10" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Merge rule node with a tag selector and child aspect node</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table10" xlink:to="label_table10"/>

      <!-- X axis -->
      <table:breakdown xlink:type="resource" xlink:label="table10-x" id="table10-x"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="x" xlink:from="table10" xlink:to="table10-x" order="1"/>

      <table:ruleNode xlink:type="resource" xlink:label="table10-x.1" id="table10-x.1">
        <table:ruleSet tag="instant">
          <formula:period>
            <formula:instant value="xs:date('2001-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <formula:period>
          <formula:duration start="xs:date('2002-01-01')" end="xs:date('2002-12-31')"/>
        </formula:period>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table10-x" xlink:to="table10-x.1" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table10-x.11" id="label_table10-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">2002</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table10-x.1" xlink:to="label_table10-x.11"/>

      <!-- Y axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table10-y" id="table10-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="y" xlink:from="table10" xlink:to="table10-y" order="2"/>
      
      <table:ruleNode xlink:type="resource" xlink:label="table10-y.1" id="table10-y.1" abstract="true" merge="true" tagSelector="instant" />
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table10-y" xlink:to="table10-y.1" order="1"/>
      
      <table:aspectNode xlink:type="resource" xlink:label="table10-y.1.1" id="table10-y.1.1">
        <table:conceptAspect/>
      </table:aspectNode>
      <table:definitionNodeSubtreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:from="table10-y.1" xlink:to="table10-y.1.1" order="1"/>

   </gen:link>

</link:linkbase>