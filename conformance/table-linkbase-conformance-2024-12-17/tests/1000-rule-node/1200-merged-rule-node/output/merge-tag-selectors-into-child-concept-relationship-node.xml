<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Merge rule node with a tag selector and child concept relationship node</label>
    <table>
      <headers axis="y">
        <group>
          <header>
            <cell>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <header>
            <cell>
              <label>2002</label>
              <constraint tag="table.periodStart">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2002-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2003-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
              <constraint tag="table.periodEnd">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="z">
        <group>
          <header>
            <cell>
              <label>Company ID</label>
              <constraint tag="oldID">
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme/old">abc</xbrli:identifier>
                </value>
              </constraint>
              <constraint>
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme/new">12345678</xbrli:identifier>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <!-- Top and bottom rows get the tag selectors for period start and end; middle row gets the tag selector from the merged rule node. -->
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>merge-tag-selectors-into-child-concept-relationship-node-instance.xml#m1_start2002_newID</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>merge-tag-selectors-into-child-concept-relationship-node-instance.xml#o1_year2002_oldID</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>merge-tag-selectors-into-child-concept-relationship-node-instance.xml#m2_end2002_newID</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>