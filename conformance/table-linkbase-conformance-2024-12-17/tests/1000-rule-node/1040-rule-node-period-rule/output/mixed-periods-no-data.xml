<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Rule nodes with both instant and duration period rules</label>
    <table>
      <headers axis="y">
        <group>
          <label>Three rows (primary items m1, m2, o1)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o1</label>
              <label>3</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Three columns (periods 2001-12-31, 2002-12-31, 2002)</label>
          <header>
            <cell span="3">
              <label>Label: Period = 2002</label>
              <label>3</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2002-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2003-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
          </header>
          <header>
            <cell>
              <label>Label: Period = Start</label>
              <label>1</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>Label: Period = End</label>
              <label>2</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
            <cell rollup="true"/>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell/>
            <cell/>
            <cell/>
          </cells>
          <cells axis="x">
            <cell/>
            <cell/>
            <cell/>
          </cells>
          <cells axis="x">
            <cell/>
            <cell/>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>