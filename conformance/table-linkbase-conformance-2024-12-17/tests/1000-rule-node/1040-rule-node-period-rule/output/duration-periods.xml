<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Rule nodes with duration period rules</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items o1, o2)</label>
          <header>
            <cell>
              <label>Label: o1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (periods 2001, 2002)</label>
          <header>
            <cell>
              <label>Label: Period = 2001</label>
              <label>1</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2001-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2002-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>Label: Period = 2002</label>
              <label>2</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2002-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2003-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>duration-periods-instance.xml#o1_y2001</fact>
            </cell>
            <cell>
              <fact>duration-periods-instance.xml#o1_y2002</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>duration-periods-instance.xml#o2_y2001</fact>
            </cell>
            <cell>
              <fact>duration-periods-instance.xml#o2_y2002</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>