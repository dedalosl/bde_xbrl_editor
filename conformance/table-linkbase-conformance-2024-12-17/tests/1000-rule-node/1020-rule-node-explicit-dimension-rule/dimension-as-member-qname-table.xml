<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:reference="http://xbrl.org/2008/reference"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table9"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#table9"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple"
                 xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table9">

      <table:table xlink:type="resource" xlink:label="table9" id="table9"/>
      <label:label xlink:type="resource" xlink:label="label_table9" id="label_table9"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Explicit dimension rule for a domain member that is actually a dimension</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9"
               xlink:to="label_table9"/>

<!-- Declare X axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table9-x" id="table9-x"/>
<!-- Connect table to X axis -->
      <table:tableBreakdownArc xlink:type="arc"
                               xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="x"
                               xlink:from="table9"
                               xlink:to="table9-x"
                               order="4"/>
<!-- Create appropriate label for first breakdown on X axis -->
      <label:label xlink:type="resource" xlink:label="label_table9-x"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table9-x">Primary item</label:label>
<!-- Connect label to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-x"
               xlink:to="label_table9-x"/>

<!-- Find content for first column header on X axis by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table9-x.1" id="table9-x.1">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qname>rend:E</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect second column header to X axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table9-x"
                              xlink:to="table9-x.1"
                              order="4"/>
<!-- Create appropriate label for first column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table9-x.11" id="label_table9-x.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = E</label:label>
<!-- Connect first column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-x.1"
               xlink:to="label_table9-x.11"/>
<!-- Create appropriate label for first column and first row header on X axis (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table9-x.12" id="label_table9-x.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
<!-- Connect first column and first row header label on X axis to X axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-x.1"
               xlink:to="label_table9-x.12"/>

<!-- Declare Y axis, it is abstract and has no header, so it can be parent for two ordinates -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table9-y" id="table9-y"/>
<!-- Connect table to Y axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="y"
                          xlink:from="table9"
                          xlink:to="table9-y"
                          order="6"/>
<!-- Create appropriate label for first breakdown on Y axis -->
      <label:label xlink:type="resource" xlink:label="label_table9-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table9-y">Two columns (dimension D = d1, d2)</label:label>
<!-- Connect label to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-y"
               xlink:to="label_table9-y"/>
<!-- Find content for first column header on Y axis by stating the primary -->
      <table:ruleNode xlink:type="resource" xlink:label="table9-y.1" id="table9-y.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
<!-- Connect Y axis content to Y axis -->
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table9-y"
               xlink:to="table9-y.1"
               order="2"/>
<!-- Create appropriate label for first column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table9-y.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table9-y.11">Label: m1</label:label>
<!-- Connect first column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-y.1"
               xlink:to="label_table9-y.11"/>
      <label:label xlink:type="resource" xlink:label="label_table9-y.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table9-y.12">1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-y.1"
               xlink:to="label_table9-y.12"/>
      <table:ruleNode xlink:type="resource" xlink:label="table9-y.2" id="table9-y.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table9-y"
               xlink:to="table9-y.2"
               order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table9-y.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table9-y.21">Label: m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-y.2"
               xlink:to="label_table9-y.21"/>
      <label:label xlink:type="resource" xlink:label="label_table9-y.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table9-y.22">2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table9-y.2"
               xlink:to="label_table9-y.22"/>
   </gen:link>

</link:linkbase>