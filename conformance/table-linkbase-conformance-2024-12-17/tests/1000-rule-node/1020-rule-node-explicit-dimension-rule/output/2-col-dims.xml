<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <!--Entry point file: instance-2-col-dims.xml-->
  <tableSet>
    <!--TableSet linkbase file: table-linkbase-2-col-dims.xml, line 38-->
    <!--TableSet namespace: http://xbrl.org/2014/table-->
    <!--TableSet linkrole: http://www.xbrl.org/table-examples/table1-->
    <label>This table shows a simple hierarchy in the x axis: a top header that establishes the value for dimension D = d0. This header has two children giving values e1 and e2 to dimension E. As a result, column 1 values are associated to dim D= d0 and E = e1 (coordinates are inherited); column 2 values are associated to dimension D = d0 and E = e2.</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <!--ruleNode: label table1-y.1, file table-linkbase-2-col-dims.xml, line 131-->
            <!--   aspect concept: rend:m1-->
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-y.2, file table-linkbase-2-col-dims.xml, line 155-->
            <!--   aspect concept: rend:m2-->
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (dimension [D, E] = [d0, e1], [d0, e2])</label>
          <header>
            <!--ruleNode: label table1-x.1, file table-linkbase-2-col-dims.xml, line 53-->
            <!--   aspect rend:D: rend:d0-->
            <cell span="2">
              <label>Label: D = d0</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value/>
              </constraint>
            </cell>
          </header>
          <header>
            <!--ruleNode: label table1-x.1.1, file table-linkbase-2-col-dims.xml, line 72-->
            <!--   aspect rend:E: rend:e1-->
            <cell>
              <label>Label: E = e1</label>
              <label>1</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e1</value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-x.1.2, file table-linkbase-2-col-dims.xml, line 98-->
            <!--   aspect rend:E: rend:e2-->
            <cell>
              <label>Label: E = e2</label>
              <label>2</label>
              <constraint>
                <aspect>rend:E</aspect>
                <value>rend:e2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <!--rend:m1: context D_d0_E_e1, file instance-2-col-dims.xml, line 43-->
            <cell>
              <fact>instance-2-col-dims.xml#m1_D_d0_E_e1</fact>
            </cell>
            <!--rend:m1: context D_d0_E_e2, file instance-2-col-dims.xml, line 51-->
            <cell>
              <fact>instance-2-col-dims.xml#m1_D_d0_E_e2</fact>
            </cell>
          </cells>
          <cells axis="x">
            <!--rend:m2: context D_d0_E_e1, file instance-2-col-dims.xml, line 47-->
            <cell>
              <fact>instance-2-col-dims.xml#m2_D_d0_E_e1</fact>
            </cell>
            <!--rend:m2: context D_d0_E_e2, file instance-2-col-dims.xml, line 55-->
            <cell>
              <fact>instance-2-col-dims.xml#m2_D_d0_E_e2</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>