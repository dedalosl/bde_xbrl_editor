<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Simple table with three columns (dimension D = d1, d2, d0), and two rows (primary items m1, m2)</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Three columns (dimension D = d1, d2, d0)</label>
          <header>
            <cell>
              <label>Label: D = d1</label>
              <label>1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: D = d2</label>
              <label>2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: D = d0</label>
              <label>3</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value/>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m1_D_d1</fact>
            </cell>
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m1_D_d2</fact>
            </cell>
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m1_D_d0</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m2_D_d1</fact>
            </cell>
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m2_D_d2</fact>
            </cell>
            <cell>
              <fact>instance-2-col-dims-defaulted.xml#m2_D_d0</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>