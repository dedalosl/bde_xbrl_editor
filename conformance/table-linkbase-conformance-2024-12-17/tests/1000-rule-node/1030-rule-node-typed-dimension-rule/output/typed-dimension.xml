    <label>Simple table with three columns (typed dimension Age = .. - 20, 21 - 40, 41 - ..), and two rows (primary items Number of Employees, Average Salary)</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items Number of Employees, Average Salary)</label>
          <header>
            <!--ruleNode: label table1-y.1, file typed-dimension-table.xml, line 167-->
            <!--   aspect concept: rend:NumberOfEmployees-->
            <cell>
              <label>Number of Employees</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:NumberOfEmployees</value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-y.2, file typed-dimension-table.xml, line 194-->
            <!--   aspect concept: rend:AverageSalary-->
            <cell>
              <label>Average Salary</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:AverageSalary</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Three columns (typed dimension Age = .. - 20, 21 - 40, 41 - ..)</label>
          <header>
            <!--ruleNode: label table1-x.1, file typed-dimension-table.xml, line 61-->
            <!--   aspect rend:Age: ModelObject[1359, typed-dimension-table.xml line 64)-->
            <cell>
              <label>.. - 20</label>
              <label>1</label>
              <constraint>
                <aspect>rend:Age</aspect>
                <value>
                  <rend:Age.domain>.. - 20</rend:Age.domain>
                </value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-x.2, file typed-dimension-table.xml, line 93-->
            <!--   aspect rend:Age: ModelObject[1368, typed-dimension-table.xml line 96)-->
            <cell>
              <label>21 - 40</label>
              <label>2</label>
              <constraint>
                <aspect>rend:Age</aspect>
                <value>
                  <rend:Age.domain>21 - 40</rend:Age.domain>
                </value>
              </constraint>
            </cell>
            <!--ruleNode: label table1-x.3, file typed-dimension-table.xml, line 125-->
            <!--   aspect rend:Age: ModelObject[1377, typed-dimension-table.xml line 128)-->
            <cell>
              <label>41 - ..</label>
              <label>3</label>
              <constraint>
                <aspect>rend:Age</aspect>
                <value>
                  <rend:Age.domain>41 - ..</rend:Age.domain>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>typed-dimension-instance.xml#NumberOfEmployees_agesUpTo20</fact>
            </cell>
            <cell>
              <fact>typed-dimension-instance.xml#NumberOfEmployees_ages21to40</fact>
            </cell>
            <cell>
              <fact>typed-dimension-instance.xml#NumberOfEmployees_ages41plus</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>typed-dimension-instance.xml#AverageSalary_agesUpTo20</fact>
            </cell>
            <cell>
              <fact>typed-dimension-instance.xml#AverageSalary_ages21to40</fact>
            </cell>
            <cell>
              <fact>typed-dimension-instance.xml#AverageSalary_ages41plus</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
