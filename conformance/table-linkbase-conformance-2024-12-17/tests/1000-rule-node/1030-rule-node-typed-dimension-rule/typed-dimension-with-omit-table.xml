      <table:ruleNode xlink:type="resource" xlink:label="table3-x.1" id="table3-x.1" abstract="true">
         <formula:typedDimension dimension="rend:Age">
            <formula:value>
               <rend:Age.domain>.. - 20</rend:Age.domain>
            </formula:value>
         </formula:typedDimension>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table3-x" xlink:to="table3-x.1" order="1"/>

      <label:label xlink:type="resource" xlink:label="label_table3-x.11" id="label_table3-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">.. - 20</label:label>
