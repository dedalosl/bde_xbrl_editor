<?xml version="1.0" encoding="utf-8"?>
<xbrli:xbrl
  xmlns:rend="http://www.xbrl.org/table-examples-typed"
  xmlns:iso4217="http://www.xbrl.org/2003/iso4217"
  xmlns:link="http://www.xbrl.org/2003/linkbase"
  xmlns:xbrldi="http://xbrl.org/2006/xbrldi"
  xmlns:xbrli="http://www.xbrl.org/2003/instance"
  xmlns:xl="http://www.xbrl.org/2003/XLink"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://xbrl.org/2006/xbrldi http://www.xbrl.org/2006/xbrldi-2006.xsd">
    <link:schemaRef xlink:href="typed-dimension-example.xsd" xlink:type="simple"/>
    <link:linkbaseRef xlink:type="simple" xlink:arcrole="http://www.w3.org/1999/xlink/properties/linkbase" xlink:href="typed-dimension-table.xml"/>  
    <xbrli:context id="agesUpTo20">
        <xbrli:entity>
            <xbrli:identifier scheme="http://scheme">ABC Corp.</xbrli:identifier>
        </xbrli:entity>
        <xbrli:period>
            <xbrli:instant>2011-12-31</xbrli:instant>
        </xbrli:period>
        <xbrli:scenario>
            <xbrldi:typedMember dimension="rend:Age">
              <rend:Age.domain>.. - 20</rend:Age.domain>
            </xbrldi:typedMember>
        </xbrli:scenario>
    </xbrli:context>
    <xbrli:context id="ages21to40">
        <xbrli:entity>
            <xbrli:identifier scheme="http://scheme">ABC Corp.</xbrli:identifier>
        </xbrli:entity>
        <xbrli:period>
            <xbrli:instant>2011-12-31</xbrli:instant>
        </xbrli:period>
        <xbrli:scenario>
            <xbrldi:typedMember dimension="rend:Age">
              <rend:Age.domain>21 - 40</rend:Age.domain>
            </xbrldi:typedMember>
        </xbrli:scenario>
    </xbrli:context>
    <xbrli:context id="ages41plus">
        <xbrli:entity>
            <xbrli:identifier scheme="http://scheme">ABC Corp.</xbrli:identifier>
        </xbrli:entity>
        <xbrli:period>
            <xbrli:instant>2011-12-31</xbrli:instant>
        </xbrli:period>
        <xbrli:scenario>
            <xbrldi:typedMember dimension="rend:Age">
              <rend:Age.domain>41 - ..</rend:Age.domain>
            </xbrldi:typedMember>
        </xbrli:scenario>
    </xbrli:context>
    <xbrli:unit id="pure">
      <xbrli:measure>
        xbrli:pure
      </xbrli:measure>
    </xbrli:unit>
    <xbrli:unit id="EUR">
        <xbrli:measure>iso4217:EUR</xbrli:measure>
    </xbrli:unit>
    <rend:NumberOfEmployees id="NumberOfEmployees_agesUpTo20" decimals="0" contextRef="agesUpTo20" unitRef="pure">1</rend:NumberOfEmployees>
    <rend:NumberOfEmployees id="NumberOfEmployees_ages21to40" decimals="0" contextRef="ages21to40" unitRef="pure">10</rend:NumberOfEmployees>
    <rend:NumberOfEmployees id="NumberOfEmployees_ages41plus" decimals="0" contextRef="ages41plus" unitRef="pure">5</rend:NumberOfEmployees>
    <rend:AverageSalary id="AverageSalary_agesUpTo20" decimals="0" contextRef="agesUpTo20" unitRef="EUR">20000</rend:AverageSalary>
    <rend:AverageSalary id="AverageSalary_ages21to40" decimals="0" contextRef="ages21to40" unitRef="EUR">30000</rend:AverageSalary>
    <rend:AverageSalary id="AverageSalary_ages41plus" decimals="0" contextRef="ages41plus" unitRef="EUR">50000</rend:AverageSalary>
</xbrli:xbrl>