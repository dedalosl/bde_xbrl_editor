<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table7" xlink:type="simple" xlink:href="table-examples-roles.xsd#table7"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code" xlink:type="simple" xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table7">

      <table:table xlink:type="resource" xlink:label="table7" id="table7"/>
      <label:label xlink:type="resource" xlink:label="label_table7" id="label_table7" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Multiple rule nodes with tagged rule sets</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7" xlink:to="label_table7"/>

      <!-- X axis -->
      <table:breakdown xlink:type="resource" xlink:label="table7-x" id="table7-x"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="x" xlink:from="table7" xlink:to="table7-x" order="1"/>

      <table:ruleNode xlink:type="resource" xlink:label="table7-x.1" id="table7-x.1" tagSelector="oldID">
        <table:ruleSet tag="start">
          <formula:period>
            <formula:instant value="xs:date('2001-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <table:ruleSet tag="end">
          <formula:period>
            <formula:instant value="xs:date('2002-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <formula:period>
          <formula:duration start="xs:date('2002-01-01')" end="xs:date('2002-12-31')"/>
        </formula:period>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-x" xlink:to="table7-x.1" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table7-x.11" id="label_table7-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">2002</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-x.1" xlink:to="label_table7-x.11"/>
      
      <table:ruleNode xlink:type="resource" xlink:label="table7-x.2" id="table7-x.2">
        <table:ruleSet tag="start">
          <formula:period>
            <formula:instant value="xs:date('2002-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <table:ruleSet tag="end">
          <formula:period>
            <formula:instant value="xs:date('2003-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <formula:period>
          <formula:duration start="xs:date('2003-01-01')" end="xs:date('2003-12-31')"/>
        </formula:period>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-x" xlink:to="table7-x.2" order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table7-x.21" id="label_table7-x.21" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">2003</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-x.2" xlink:to="label_table7-x.21"/>

      <!-- Y axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-y" id="table7-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="y" xlink:from="table7" xlink:to="table7-y" order="2"/>

      <table:ruleNode xlink:type="resource" xlink:label="table7-y.1" id="table7-y.1" tagSelector="start">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-y" xlink:to="table7-y.1" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table7-y.11" id="label_table7-y.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">m1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-y.1" xlink:to="label_table7-y.11"/>

      <table:ruleNode xlink:type="resource" xlink:label="table7-y.2" id="table7-y.2">
         <formula:concept>
            <formula:qname>rend:o1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-y" xlink:to="table7-y.2" order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table7-y.21" id="label_table7-y.21" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">o1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-y.2" xlink:to="label_table7-y.21"/>
      
      <table:ruleNode xlink:type="resource" xlink:label="table7-y.3" id="table7-y.3" tagSelector="end">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-y" xlink:to="table7-y.3" order="3"/>
      <label:label xlink:type="resource" xlink:label="label_table7-y.31" id="label_table7-y.31" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-y.3" xlink:to="label_table7-y.31"/>
   
   
      <!-- Z axis -->
      
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-z" id="table7-z"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="z" xlink:from="table7" xlink:to="table7-z" order="3"/>
   
      <table:ruleNode xlink:type="resource" xlink:label="table7-z.1" id="table7-z.1">
         <table:ruleSet tag="oldID">
             <formula:entityIdentifier scheme="'http://scheme/old'" value="'abc'" />
           </table:ruleSet>
           <formula:entityIdentifier scheme="'http://scheme/new'" value="'12345678'" />
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-z" xlink:to="table7-z.1" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table7-z.11" id="label_table7-z.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Company ID</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-z.1" xlink:to="label_table7-z.11"/>
   
   </gen:link>

</link:linkbase>