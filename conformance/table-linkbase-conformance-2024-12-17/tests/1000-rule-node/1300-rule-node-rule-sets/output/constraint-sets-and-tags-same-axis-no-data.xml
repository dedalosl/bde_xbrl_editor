<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Table with tags and constraint sets on the same axis</label>
    <table>
      <headers axis="x">
        <group>
          <header>
            <cell span="2">
              <label>2002</label>
              <constraint tag="start">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
              <constraint tag="end">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
        <group>
          <header>
            <cell>
              <label>m1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>m2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell/>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>