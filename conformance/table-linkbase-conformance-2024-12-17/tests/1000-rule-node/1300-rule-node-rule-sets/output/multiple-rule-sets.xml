<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Multiple rule nodes with tagged rule sets</label>
    <table>
      <headers axis="y">
        <group>
          <header>
            <cell>
              <label>m1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>o1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <label>m2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <header>
            <cell>
              <label>2002</label>
              <constraint tag="start">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2002-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2003-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
              <constraint tag="end">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>2003</label>
              <constraint tag="start">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2003-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2004-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
              <constraint tag="end">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2004-01-01T00:00:00Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="z">
        <group>
          <header>
            <cell>
              <label>Company ID</label>
              <constraint tag="oldID">
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme/old">abc</xbrli:identifier>
                </value>
              </constraint>
              <constraint>
                <aspect>entity-identifier</aspect>
                <value>
                  <xbrli:identifier scheme="http://scheme/new">12345678</xbrli:identifier>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>multiple-rule-sets-instance.xml#m1_start2002</fact>
            </cell>
            <cell>
              <fact>multiple-rule-sets-instance.xml#m1_start2003</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>multiple-rule-sets-instance.xml#o1_year2002</fact>
            </cell>
            <cell>
              <fact>multiple-rule-sets-instance.xml#o1_year2003</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>multiple-rule-sets-instance.xml#m2_end2002</fact>
            </cell>
            <cell>
              <fact>multiple-rule-sets-instance.xml#m2_end2003</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>