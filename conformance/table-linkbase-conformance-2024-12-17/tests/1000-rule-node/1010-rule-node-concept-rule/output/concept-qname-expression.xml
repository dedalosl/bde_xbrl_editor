<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <!--Entry point file: concept-qname-expression-instance.xml-->
  <tableSet>
    <label>Rule nodes with concept rules that use XPath expressions</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <!--   aspect concept: rend:m1-->
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <!--   aspect concept: rend:m2-->
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (dimension D = d1, d2)</label>
          <header>
            <!--   aspect rend:D: rend:d1-->
            <cell>
              <label>Label: D = d1</label>
              <label>1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
            </cell>
            <!--   aspect rend:D: rend:d2-->
            <cell>
              <label>Label: D = d2</label>
              <label>2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <!--rend:m1: context D_d1-->
            <cell>
              <fact>concept-qname-expression-instance.xml#m1_D_d1</fact>
            </cell>
            <!--rend:m1: context D_d2-->
            <cell>
              <fact>concept-qname-expression-instance.xml#m1_D_d2</fact>
            </cell>
          </cells>
          <cells axis="x">
            <!--rend:m2: context D_d1-->
            <cell>
              <fact>concept-qname-expression-instance.xml#m2_D_d1</fact>
            </cell>
            <!--rend:m2: context D_d2-->
            <cell>
              <fact>concept-qname-expression-instance.xml#m2_D_d2</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>