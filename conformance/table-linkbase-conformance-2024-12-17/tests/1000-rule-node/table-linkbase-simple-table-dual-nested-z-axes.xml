<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:reference="http://xbrl.org/2008/reference"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2008/filter/dimension http://www.xbrl.org/2008/dimension-filter.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table7"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#table7"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code"
                 xlink:type="simple"
                 xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple"
                 xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

<!-- Table 9, an example of a table with 2 breakdowns on the z-axis -->
   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table7">

<!-- Declare table as a resource -->
      <table:table xlink:type="resource" xlink:label="table7" id="table7"/>
<!-- Create appropriate label for the table -->
      <label:label xlink:type="resource" xlink:label="label_table71" id="label_table71"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Table with dual breakdowns on the z-axis</label:label>
<!-- Connect table resource to table label -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7"
               xlink:to="label_table71"/>

<!-- Declare first Z axis breakdown -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-z1" id="table7-z1"/>
<!-- Connect table to first Z axis breakdown -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="z"
                               xlink:from="table7"
                               xlink:to="table7-z1"
                               order="4"/>

<!-- Find content for first column header on the first Z axis breakdown by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-z1.1" id="table7-z1.1">
         <formula:explicitDimension dimension="rend:F">
            <formula:member>
               <formula:qname>rend:f1</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect first column header to first Z axis breakdown -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table7-z1"
                              xlink:to="table7-z1.1"
                              order="2"/>
<!-- Create appropriate label for first breakdown on Z axis -->
      <label:label xlink:type="resource" xlink:label="label_table7-z1"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table7-z1">Two slices (dimension F = f1, f2)</label:label>
<!-- Connect label to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z1"
               xlink:to="label_table7-z1"/>
<!-- Create appropriate label for first column and first row header on the first Z axis breakdown (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z1.11" id="label_table7-z1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: F = f1</label:label>
<!-- Connect first row header label on the first Z axis breakdown to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z1.1"
               xlink:to="label_table7-z1.11"/>
<!-- Create appropriate label for first column and second row header on the first Z axis breakdown (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z1.12" id="label_table7-z1.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
<!-- Connect second row header label on the first Z axis breakdown to Z axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z1.1"
               xlink:to="label_table7-z1.12"/>

<!-- Find content for second column header on the first Z axis breakdown by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-z1.1.1" id="table7-z1.1.1">
         <formula:explicitDimension dimension="rend:F">
            <formula:member>
               <formula:qname>rend:f2</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect second column header to first Z axis breakdown -->
      <table:definitionNodeSubtreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/definition-node-subtree"
               xlink:from="table7-z1.1"
               xlink:to="table7-z1.1.1"
               order="8"/>
<!-- Create appropriate label for second column and first row header on the first Z axis breakdown (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z1.1.11" id="label_table7-z1.1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: F = f2</label:label>
<!-- Connect second row header label on the first Z axis breakdown to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z1.1.1"
               xlink:to="label_table7-z1.1.11"/>
<!-- Create appropriate label for second column and second row header on the first Z axis breakdown (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z1.1.12" id="label_table7-z1.1.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
<!-- Connect second row header label on the first Z axis breakdown to Z axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z1.1.1"
               xlink:to="label_table7-z1.1.12"/>

<!-- Declare second Z axis breakdown -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-z2" id="table7-z2" />
<!-- Connect table to second Z axis breakdown -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="z"
                               xlink:from="table7"
                               xlink:to="table7-z2"
                               order="6"/>
<!-- Create appropriate label for second breakdown on Z axis -->
      <label:label xlink:type="resource" xlink:label="label_table7-z2"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table7-z2">Two slices (dimension G = g1, g2)</label:label>
<!-- Connect label to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z2"
               xlink:to="label_table7-z2"/>

<!-- Find content for first column header on the second Z axis breakdown by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-z2.1" id="table7-z2.1">
         <formula:explicitDimension dimension="rend:G">
            <formula:member>
               <formula:qname>rend:g1</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect first column header to second Z axis breakdown -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table7-z2"
                              xlink:to="table7-z2.1"
                              order="2"/>
<!-- Create appropriate label for first column and first row header on the second Z axis breakdown (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z2.11" id="label_table7-z2.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: G = g1</label:label>
<!-- Connect first row header label on the second Z axis breakdown to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z2.1"
               xlink:to="label_table7-z2.11"/>
<!-- Create appropriate label for first column and second row header on the second Z axis breakdown (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z2.12" id="label_table7-z2.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
<!-- Connect second row header label on the second Z axis breakdown to Z axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z2.1"
               xlink:to="label_table7-z2.12"/>

<!-- Find content for second column header on the second Z axis breakdown by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-z2.1.1" id="table7-z2.1.1">
         <formula:explicitDimension dimension="rend:G">
            <formula:member>
               <formula:qname>rend:g2</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect second column header to second Z axis breakdown -->
      <table:definitionNodeSubtreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/definition-node-subtree"
               xlink:from="table7-z2.1"
               xlink:to="table7-z2.1.1"
               order="8"/>
<!-- Create appropriate label for second column and first row header on the second Z axis breakdown (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z2.1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   id="label_table7-z2.1.11">Label: G = g2</label:label>
<!-- Connect first row header label on the second Z axis breakdown to Z axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z2.1.1"
               xlink:to="label_table7-z2.1.11"/>
<!-- Create appropriate label for second column and second row header on the second Z axis breakdown (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-z2.1.12" id="label_table7-z2.1.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
<!-- Connect second row header label on the second Z axis breakdown to Z axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-z2.1.1"
               xlink:to="label_table7-z2.1.12"/>

<!-- Declare X axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-x" id="table7-x"/>
<!-- Connect table to X axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="x"
                               xlink:from="table7"
                               xlink:to="table7-x"
                               order="8"/>
<!-- Create appropriate label for first breakdown on X axis -->
      <label:label xlink:type="resource" xlink:label="label_table7-x"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table7-x">Two columns (dimension D = d1, d2)</label:label>
<!-- Connect label to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-x"
               xlink:to="label_table7-x"/>

<!-- Find content for first column header on X axis by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-x.1" id="table7-x.1">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qname>rend:d1</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect first column header to X axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table7-x"
                              xlink:to="table7-x.1"
                              order="2"/>
<!-- Create appropriate label for first column and first row header on X axis (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-x.11" id="label_table7-x.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = d1</label:label>
<!-- Connect first row header label on X axis to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-x.1"
               xlink:to="label_table7-x.11"/>
<!-- Create appropriate label for first column and second row header on X axis (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-x.12" id="label_table7-x.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
<!-- Connect second row header label on X axis to X axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-x.1"
               xlink:to="label_table7-x.12"/>

<!-- Find content for second column header on X axis by stating the dimension and member -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-x.2" id="table7-x.2">
         <formula:explicitDimension dimension="rend:D">
            <formula:member>
               <formula:qname>rend:d2</formula:qname>
            </formula:member>
         </formula:explicitDimension>
      </table:ruleNode>
<!-- Connect second column header to X axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table7-x"
                              xlink:to="table7-x.2"
                              order="4"/>
<!-- Create appropriate label for second column and first row header on X axis (Something to represent the dimension and member in this example) -->
      <label:label xlink:type="resource" xlink:label="label_table7-x.21" id="label_table7-x.21"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: D = d2</label:label>
<!-- Connect first row header label on X axis to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-x.2"
               xlink:to="label_table7-x.21"/>
<!-- Create appropriate label for second column and second row header on X axis (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-x.22" id="label_table7-x.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
<!-- Connect second row header label on X axis to X axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-x.2"
               xlink:to="label_table7-x.22"/>

<!-- Declare Y axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-y" id="table7-y"/>
<!-- Connect table to Y axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                               axis="y"
                               xlink:from="table7"
                               xlink:to="table7-y"
                               order="10"/>
<!-- Create appropriate label for first breakdown on Y axis -->
      <label:label xlink:type="resource" xlink:label="label_table7-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table7-y">Two rows (primary items m1, m2)</label:label>
<!-- Connect label to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-y"
               xlink:to="label_table7-y"/>
<!-- Find content for first column header on Y axis by stating the primary -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-y.1" id="table7-y.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
<!-- Connect first column header to Y axis -->
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table7-y"
               xlink:to="table7-y.1"
               order="2"/>
<!-- Create appropriate label for first column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table7-y.11" id="label_table7-y.11"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: m1</label:label>
<!-- Connect first column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-y.1"
               xlink:to="label_table7-y.11"/>
<!-- Create appropriate label for first column and second row header on Y axis (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-y.12" id="label_table7-y.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >1</label:label>
<!-- Connect first column and second row header label on Y axis to Y axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-y.1"
               xlink:to="label_table7-y.12"/>

<!-- Find content for second column header on Y axis by stating the primary -->
      <table:ruleNode xlink:type="resource" xlink:label="table7-y.2" id="table7-y.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
<!-- Connect second column header to Y axis -->
      <table:breakdownTreeArc xlink:type="arc"
                              xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                              xlink:from="table7-y"
                              xlink:to="table7-y.2"
                              order="4"/>

<!-- Create appropriate label for second column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table7-y.21" id="label_table7-y.21"
                   xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en"
                   >Label: m2</label:label>
<!-- Connect second column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-y.2"
               xlink:to="label_table7-y.21"/>
<!-- Create appropriate label for second column and second row header on Y axis (Something to represent an Eurofiling pointer) -->
      <label:label xlink:type="resource" xlink:label="label_table7-y.22" id="label_table7-y.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code" xml:lang="en"
                   >2</label:label>
<!-- Connect second column and second row header label on Y axis to Y axis content -->
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table7-y.2"
               xlink:to="label_table7-y.22"/>
   </gen:link>

</link:linkbase>