<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xmlns:xbrli="http://www.xbrl.org/2003/instance" xml:base="..">
  <tableSet>
    <label>Concept relationship node a period start preferred label on a non-abstract parent concept</label>
    <table>
      <headers axis="y">
        <group>
          <label>Presentation tree for primary items</label>
          <header>
            <cell span="3">
              <constraint>
                <aspect>concept</aspect>
                <value>rend:base</value>
              </constraint>
            </cell>
          </header>
          <header>
            <cell span="3">
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
          </header>
          <header>
            <cell rollup="true"/>
            <cell>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (periods 2001, 2002)</label>
          <header>
            <cell>
              <label>Label: 2001</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2001-01-01T00:00:00.000Z</xbrli:startDate>
                  <xbrli:endDate>2002-01-01T00:00:00.000Z</xbrli:endDate>
                </value>
              </constraint>
              <constraint tag="table.periodStart">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2001-01-01T00:00:00.000Z</xbrli:instant>
                </value>
              </constraint>
              <constraint tag="table.periodEnd">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00.000Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
            <cell>
              <label>Label: 2002</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2002-01-01T00:00:00.000Z</xbrli:startDate>
                  <xbrli:endDate>2003-01-01T00:00:00.000Z</xbrli:endDate>
                </value>
              </constraint>
              <constraint tag="table.periodStart">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2002-01-01T00:00:00.000Z</xbrli:instant>
                </value>
              </constraint>
              <constraint tag="table.periodEnd">
                <aspect>period</aspect>
                <value>
                  <xbrli:instant>2003-01-01T00:00:00.000Z</xbrli:instant>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#m1_end2000</fact>
            </cell>
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#m1_end2001</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#o1_Y2001</fact>
            </cell>
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#o1_Y2002</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#m2_end2001</fact>
            </cell>
            <cell>
              <fact>tag-selector-on-rollup-instance.xml#m2_end2002</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>