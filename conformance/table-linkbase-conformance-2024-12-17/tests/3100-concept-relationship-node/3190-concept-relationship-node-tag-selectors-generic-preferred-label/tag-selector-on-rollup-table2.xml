<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xsi:schemaLocation="             
                  http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                  http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                  http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                  http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table2" xlink:type="simple" xlink:href="table-examples2-roles.xsd#table2"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code" xlink:type="simple" xlink:href="table-examples2-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>

   <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table2">

      <table:table xlink:type="resource" xlink:label="table2" id="table2"/>
      <label:label xlink:type="resource" xlink:label="label_table2" id="label_table2" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Concept relationship node a period start preferred label on a non-abstract parent concept</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table2" xlink:to="label_table2"/>

      <!-- X axis -->
      <table:breakdown xlink:type="resource" xlink:label="table2-x" id="table2-x"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="x" xlink:from="table2" xlink:to="table2-x" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table2-x" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table2-x" xml:lang="en">Two columns (periods 2001, 2002)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table2-x" xlink:to="label_table2-x"/>

      <table:ruleNode xlink:type="resource" xlink:label="table2-x.1" id="table2-x.1">
        <formula:period>
          <formula:duration start="xs:date('2001-01-01')" end="xs:date('2001-12-31')"/>
        </formula:period>
        <table:ruleSet tag="table.periodStart">
          <formula:period>
            <formula:instant value="xs:date('2000-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <table:ruleSet tag="table.periodEnd">
          <formula:period>
            <formula:instant value="xs:date('2001-12-31')"/>
          </formula:period>
        </table:ruleSet>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table2-x" xlink:to="table2-x.1" order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table2-x.11" id="label_table2-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Label: 2001</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table2-x.1" xlink:to="label_table2-x.11"/>

      <table:ruleNode xlink:type="resource" xlink:label="table2-x.2" id="table2-x.2">
        <formula:period>
          <formula:duration start="xs:date('2002-01-01')" end="xs:date('2002-12-31')"/>
        </formula:period>
        <table:ruleSet tag="table.periodStart">
          <formula:period>
            <formula:instant value="xs:date('2001-12-31')"/>
          </formula:period>
        </table:ruleSet>
        <table:ruleSet tag="table.periodEnd">
          <formula:period>
            <formula:instant value="xs:date('2002-12-31')"/>
          </formula:period>
        </table:ruleSet>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table2-x" xlink:to="table2-x.2" order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table2-x.21" id="label_table2-x.21" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en">Label: 2002</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table2-x.2" xlink:to="label_table2-x.21"/>

      <!-- Y axis -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table2-y" id="table2-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="y" xlink:from="table2" xlink:to="table2-y" order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table2-y" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table2-y" xml:lang="en">Presentation tree for primary items</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table2-y" xlink:to="label_table2-y"/>

      <table:conceptRelationshipNode xlink:type="resource" xlink:label="table2-y.1" id="table2-y.1">
        <table:linkrole>http://www.xbrl.org/table-examples/roles/alt</table:linkrole>
        <table:arcrole>http://www.xbrl.org/2003/arcrole/parent-child</table:arcrole>
      </table:conceptRelationshipNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table2-y" xlink:to="table2-y.1" order="1"/>

   </gen:link>

</link:linkbase>