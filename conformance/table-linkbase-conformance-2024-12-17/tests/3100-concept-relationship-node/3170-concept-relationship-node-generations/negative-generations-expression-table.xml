<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label"
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xfi="http://www.xbrl.org/2008/function/instance"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="             
                 http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                 http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                 http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                 http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
    <link:roleRef roleURI="http://www.xbrl.org/table-examples/table7" xlink:type="simple" xlink:href="table-examples-roles.xsd#table7"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
    <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
                 
    <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table7">

        <table:table xlink:type="resource" xlink:label="table7" id="table7"/>
        <label:label xlink:type="resource" xlink:label="label_table7" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table7" xml:lang="en">Concept relationship node with a negative generations expression</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7" xlink:to="label_table7"/>

        <!-- Declare X axis -->
        <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-x" id="table7-x"/>
        <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="x" xlink:from="table7" xlink:to="table7-x"/>
        <label:label xlink:type="resource" xlink:label="label_table7-x" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table7-x" xml:lang="en">Two columns (periods 2001, 2002)</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-x" xlink:to="label_table7-x"/>

        <!-- Find content for first column header on X axis by stating the concept -->
        <table:ruleNode xlink:type="resource" xlink:label="table7-x.1" id="table7-x.1">
            <formula:period>
               <formula:duration start="xs:date('2001-01-01')" end="xs:date('2001-12-31')"/>
            </formula:period>
        </table:ruleNode>
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-x" xlink:to="table7-x.1" order="1"/>
        <label:label xlink:type="resource" xlink:label="label_table7-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en" id="label_table7-x.11">Label: 2001</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-x.1" xlink:to="label_table7-x.11"/>

        <!-- Find content for second column header on X axis by stating the concept -->
        <table:ruleNode xlink:type="resource" xlink:label="table7-x.2" id="table7-x.2">
            <formula:period>
               <formula:duration start="xs:date('2002-01-01')" end="xs:date('2002-12-31')"/>
            </formula:period>
        </table:ruleNode>
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-x" xlink:to="table7-x.2" order="2"/>
        <label:label xlink:type="resource" xlink:label="label_table7-x.21" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en" id="label_table7-x.21">Label: 2002</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-x.2" xlink:to="label_table7-x.21"/>

        <!-- Declare Y axis -->
        <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table7-y" id="table7-y"/>
        <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="y" xlink:from="table7" xlink:to="table7-y"/>
        <label:label xlink:type="resource" xlink:label="label_table7-y" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table7-y" xml:lang="en">Presentation tree for primary items</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table7-y" xlink:to="label_table7-y"/>

        <!-- Find content for Y axis by following a presentation network -->
        <table:conceptRelationshipNode xlink:type="resource" xlink:label="table7-y.1" id="table7-y.1">
            <table:relationshipSource>rend:base</table:relationshipSource>
            <table:arcrole>http://www.xbrl.org/2003/arcrole/parent-child</table:arcrole>
            <table:formulaAxis>descendant-or-self</table:formulaAxis>
            <table:generationsExpression>-1</table:generationsExpression>
        </table:conceptRelationshipNode>
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table7-y" xlink:to="table7-y.1" order="1"/>

    </gen:link>

</link:linkbase>             