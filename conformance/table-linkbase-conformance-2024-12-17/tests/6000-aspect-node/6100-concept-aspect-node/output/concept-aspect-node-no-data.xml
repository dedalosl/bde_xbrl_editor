<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Aspect node for concept</label>
    <table>
      <headers axis="y">
        <group>
          <label>Rows (primary items)</label>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (dimension D = d1, d2)</label>
          <header>
            <cell>
              <label>Label: D = d1</label>
              <label>1</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: D = d2</label>
              <label>2</label>
              <constraint>
                <aspect>rend:D</aspect>
                <value>rend:d2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z"/>
    </table>
  </tableSet>
</tableModel>