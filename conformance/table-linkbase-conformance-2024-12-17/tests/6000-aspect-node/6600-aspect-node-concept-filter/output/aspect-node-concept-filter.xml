<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <!--Entry point file: typed-dimension-instance-1.xml-->
  <tableSet>
    <label>Aspect node for a typed dimension with a concept filter</label>
    <table>
      <headers axis="y">
        <group>
          <label>Rows (typed dimension T)</label>
          <header>
            <cell>
              <constraint>
                <aspect>rend:T</aspect>
                <value>
                  <rend:stringDomain>abc</rend:stringDomain>
                </value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>rend:T</aspect>
                <value>
                  <rend:stringDomain>def</rend:stringDomain>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>aspect-node-concept-filter-instance.xml#m1_T_abc</fact>
            </cell>
            <cell>
              <fact>aspect-node-concept-filter-instance.xml#m2_T_abc</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>aspect-node-concept-filter-instance.xml#m1_T_def</fact>
            </cell>
            <cell/>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>