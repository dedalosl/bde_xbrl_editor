<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:df="http://xbrl.org/2008/filter/dimension"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:reference="http://xbrl.org/2008/reference"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="             
         http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
         http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
         http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
         http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
         http://xbrl.org/2008/filter/dimension http://www.xbrl.org/2008/dimension-filter.xsd
         http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table2"
                 xlink:type="simple"
                 xlink:href="table-examples-no-hypercubes-roles.xsd#table2"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/aspect-node-filter" xlink:type="simple"
                    xlink:href="http://www.xbrl.org/2014/table.xsd#aspect-node-filter"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code"
                 xlink:type="simple"
                 xlink:href="table-examples-no-hypercubes-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple"
                 xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
<!-- Table 1, a simple example of 2 rows of primaries by 2 columns containing 2 members of the same dimension -->
  <gen:link xlink:type="extended"
             xlink:role="http://www.xbrl.org/table-examples/table2">
<!-- Declare table as a resource -->
    <table:table xlink:type="resource" xlink:label="table2"
                   id="table2"/>
<!-- Create appropriate label for the table -->
      <label:label xlink:type="resource" xlink:label="label_table2"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2">Aspect node for an explicit dimension</label:label>
<!-- Connect table resource to table label -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2"
               xlink:to="label_table2"/>
<!-- Declare X axis -->
      <table:breakdown xlink:type="resource" xlink:label="table2-x" id="table2-x"/>
<!-- Connect table to X axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table2"
                          xlink:to="table2-x"
                          order="4"/>
<!-- Create appropriate label for first breakdown on X axis -->
      <label:label xlink:type="resource" xlink:label="label_table2-x"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-x">Columns (explicit dimension F)</label:label>
<!-- Connect label to X axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-x"
               xlink:to="label_table2-x"/>
      <table:aspectNode xlink:type="resource" xlink:label="table2-x.1" id="table2-x.1">
        <table:dimensionAspect>rend:F</table:dimensionAspect>
      </table:aspectNode>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                          xlink:from="table2-x"
                          xlink:to="table2-x.1"/>

<!-- Declare Y axis, it is abstract and has no header, so it can be parent for two ordinates -->
      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table2-y"
                      id="table2-y"/>
<!-- Connect table to Y axis -->
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="y"
                          xlink:from="table2"
                          xlink:to="table2-y"
                          order="6"/>
<!-- Create appropriate label for first breakdown on Y axis -->
      <label:label xlink:type="resource" xlink:label="label_table2-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-y">Two rows (primary items m1, m2)</label:label>
<!-- Connect label to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y"
               xlink:to="label_table2-y"/>

<!-- Find content for first column header on Y axis by stating the primary -->
      <table:ruleNode xlink:type="resource" xlink:label="table2-y.1" id="table2-y.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
<!-- Connect Y axis content to Y axis -->
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table2-y"
               xlink:to="table2-y.1"
               order="2"/>
<!-- Create appropriate label for first column and first row header on Y axis (Something to represent the primary) -->
      <label:label xlink:type="resource" xlink:label="label_table2-y.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-y.11">Label: m1</label:label>
<!-- Connect first column and first row header label on Y axis to Y axis content -->
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y.1"
               xlink:to="label_table2-y.11"/>
      <label:label xlink:type="resource" xlink:label="label_table2-y.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table2-y.12">1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y.1"
               xlink:to="label_table2-y.12"/>
      <table:ruleNode xlink:type="resource" xlink:label="table2-y.2" id="table2-y.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table2-y"
               xlink:to="table2-y.2"
               order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table2-y.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table2-y.21">Label: m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y.2"
               xlink:to="label_table2-y.21"/>
      <label:label xlink:type="resource" xlink:label="label_table2-y.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table2-y.22">2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table2-y.2"
               xlink:to="label_table2-y.22"/>
   </gen:link>

</link:linkbase>