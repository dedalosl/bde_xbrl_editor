<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:ef="http://xbrl.org/2008/filter/entity"
               xmlns:fn="http://www.w3.org/2005/xpath-functions"
               xmlns:iso4217="http://www.xbrl.org/2003/iso4217"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xfi="http://www.xbrl.org/2008/function/instance"
               xsi:schemaLocation="             
			   http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
			   http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
			   http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
			   http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
			   http://xbrl.org/2008/filter/entity http://www.xbrl.org/2008/entity-filter.xsd
               http://www.xbrl.org/table-examples table-examples.xsd
			   http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table1" xlink:type="simple" xlink:href="table-examples-roles.xsd#table1"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/aspect-node-filter" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#aspect-node-filter"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code" xlink:type="simple" xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
   <link:roleRef roleURI="http://www.xbrl.org/2010/role/message"  xlink:type="simple" xlink:href="http://www.xbrl.org/2010/generic-message.xsd#standard-message"/>

   <gen:link xlink:type="extended"
             xlink:role="http://www.xbrl.org/table-examples/table1">
      <table:table xlink:type="resource" xlink:label="table1"
                   id="table1"/>
      <label:label xlink:type="resource" xlink:label="label_table11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table11">Aspect node for a typed dimension with an entity identifier filter</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1"
               xlink:to="label_table11"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table1-x1" id="table1-x1"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table1"
                          xlink:to="table1-x1"
                          order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x1">Three columns (entities 100, 123, 456)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1"
               xlink:to="label_table1-x1"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x1.1" id="table1-x1.1">
         <formula:entityIdentifier scheme="'http://scheme'" value="'100'"/>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x1"
               xlink:to="table1-x1.1"
               order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x1.11">Label: entity = 100</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.1"
               xlink:to="label_table1-x1.11"/>

      <table:ruleNode xlink:type="resource" xlink:label="table1-x1.2" id="table1-x1.2">
         <formula:entityIdentifier scheme="'http://scheme'" value="'123'"/>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x1"
               xlink:to="table1-x1.2"
               order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x1.21">Label: entity = 123</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.2"
               xlink:to="label_table1-x1.21"/>

      <table:ruleNode xlink:type="resource" xlink:label="table1-x1.3" id="table1-x1.3">
         <formula:entityIdentifier scheme="'http://scheme'" value="'456'"/>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x1"
               xlink:to="table1-x1.3"
               order="3"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x1.31"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x1.31">Label: entity = 456</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x1.3"
               xlink:to="label_table1-x1.31"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table1-x2" id="table1-x2"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table1"
                          xlink:to="table1-x2"
                          order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x2">Two columns (primary items m1, m2)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2"
               xlink:to="label_table1-x2"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x2.1" id="table1-x2.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x2"
               xlink:to="table1-x2.1"
               order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x2.11">Label: m1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2.1"
               xlink:to="label_table1-x2.11"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table1-x2.12">1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2.1"
               xlink:to="label_table1-x2.12"/>
      <table:ruleNode xlink:type="resource" xlink:label="table1-x2.2" id="table1-x2.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table1-x2"
               xlink:to="table1-x2.2"
               order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-x2.21">Label: m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2.2"
               xlink:to="label_table1-x2.21"/>
      <label:label xlink:type="resource" xlink:label="label_table1-x2.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table1-x2.22">2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-x2.2"
               xlink:to="label_table1-x2.22"/>
               
      <table:breakdown xlink:type="resource" xlink:label="table1-y" id="table1-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="y"
                          xlink:from="table1"
                          xlink:to="table1-y"
                          order="6"/>
      <label:label xlink:type="resource" xlink:label="label_table1-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table1-y">Rows (typed dimension T)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table1-y"
               xlink:to="label_table1-y"/>
      <table:aspectNode xlink:type="resource" xlink:label="table1-y.1" id="table1-y.1">
        <table:dimensionAspect>rend:T</table:dimensionAspect>
      </table:aspectNode>
      <ef:identifier xlink:type="resource" xlink:label="filter_table1-y.1" id="filter_table1-y.1" test="fn:starts-with(xfi:identifier-value(.), '1')"/>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                          xlink:from="table1-y"
                          xlink:to="table1-y.1"/>
      <table:aspectNodeFilterArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/aspect-node-filter"
                          xlink:from="table1-y.1"
                          xlink:to="filter_table1-y.1"/>
   </gen:link>

</link:linkbase>