<?xml version="1.0" encoding="utf-8"?>
<xbrli:xbrl
  xmlns:rend="http://www.xbrl.org/table-examples"
  xmlns:iso4217="http://www.xbrl.org/2003/iso4217"
  xmlns:link="http://www.xbrl.org/2003/linkbase"
  xmlns:xbrldi="http://xbrl.org/2006/xbrldi"
  xmlns:xbrli="http://www.xbrl.org/2003/instance"
  xmlns:xl="http://www.xbrl.org/2003/XLink"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://xbrl.org/2006/xbrldi http://www.xbrl.org/2006/xbrldi-2006.xsd">
  <link:schemaRef xlink:href="table-examples.xsd" xlink:type="simple"/>
  <link:linkbaseRef xlink:href="period-aspect-node-table.xml" xlink:arcrole="http://www.w3.org/1999/xlink/properties/linkbase" xlink:type="simple"/>
  <xbrli:context id="year">
    <xbrli:entity>
        <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
      <xbrli:startDate>2001-01-01</xbrli:startDate>
      <xbrli:endDate>2001-12-31</xbrli:endDate>
    </xbrli:period>
  </xbrli:context>
  <xbrli:context id="start">
    <xbrli:entity>
      <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
        <xbrli:instant>2000-12-31</xbrli:instant>
    </xbrli:period>
  </xbrli:context>
  <xbrli:context id="end">
    <xbrli:entity>
      <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
        <xbrli:instant>2001-12-31</xbrli:instant>
    </xbrli:period>
  </xbrli:context>
  <xbrli:context id="forever">
    <xbrli:entity>
      <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
        <xbrli:forever/>
    </xbrli:period>
  </xbrli:context>
  <!-- unused, so the period should not appear in the output -->
  <xbrli:context id="unused">
    <xbrli:entity>
        <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
      <xbrli:startDate>2002-01-01</xbrli:startDate>
      <xbrli:endDate>2002-12-31</xbrli:endDate>
    </xbrli:period>
  </xbrli:context>
  <xbrli:unit id="EUR">
    <xbrli:measure>iso4217:EUR</xbrli:measure>
  </xbrli:unit>
  <rend:m1 id="m1_start" contextRef="start" decimals="0" unitRef="EUR">101</rend:m1>
  <rend:m2 id="m2_start" contextRef="start" decimals="0" unitRef="EUR">102</rend:m2>
  <rend:m1 id="m1_end" contextRef="end" decimals="0" unitRef="EUR">201</rend:m1>
  <rend:m2 id="m2_end" contextRef="end" decimals="0" unitRef="EUR">202</rend:m2>
  <rend:p1 id="p1_year" contextRef="year" decimals="0" unitRef="EUR">301</rend:p1>
  <rend:p2 id="p2_forever" contextRef="forever" decimals="0" unitRef="EUR">401</rend:p2>
</xbrli:xbrl>