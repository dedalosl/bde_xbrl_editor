<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Aspect node for a typed dimension with a typed dimension filter</label>
    <table>
      <headers axis="y">
        <group>
          <label>Rows (typed dimension R)</label>
          <header>
            <cell>
              <constraint>
                <aspect>rend:R</aspect>
                <value>
                  <rend:integerDomain>2</rend:integerDomain>
                </value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>rend:R</aspect>
                <value>
                  <rend:integerDomain>4</rend:integerDomain>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Two columns (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>aspect-node-typed-dimension-filter-instance.xml#m1_R_2</fact>
            </cell>
            <cell>
              <fact>aspect-node-typed-dimension-filter-instance.xml#m2_R_2</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>aspect-node-typed-dimension-filter-instance.xml#m1_R_4</fact>
            </cell>
            <cell>
              <fact>aspect-node-typed-dimension-filter-instance.xml#m2_R_4</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>