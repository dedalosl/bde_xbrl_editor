<?xml version="1.0" encoding="utf-8"?>
<xbrli:xbrl
  xmlns:rend="http://www.xbrl.org/table-examples"
  xmlns:iso4217="http://www.xbrl.org/2003/iso4217"
  xmlns:link="http://www.xbrl.org/2003/linkbase"
  xmlns:xbrldi="http://xbrl.org/2006/xbrldi"
  xmlns:xbrli="http://www.xbrl.org/2003/instance"
  xmlns:xl="http://www.xbrl.org/2003/XLink"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://xbrl.org/2006/xbrldi http://www.xbrl.org/2006/xbrldi-2006.xsd">
  <link:schemaRef xlink:href="table-examples.xsd" xlink:type="simple"/>
  <link:linkbaseRef xlink:href="unit-aspect-node-table.xml" xlink:arcrole="http://www.w3.org/1999/xlink/properties/linkbase" xlink:type="simple"/>
  <xbrli:context id="context">
    <xbrli:entity>
        <xbrli:identifier scheme="http://scheme">abc</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
        <xbrli:instant>2001-12-31</xbrli:instant>
    </xbrli:period>
  </xbrli:context>
  <xbrli:unit id="EUR">
    <xbrli:measure>iso4217:EUR</xbrli:measure>
  </xbrli:unit>
  <xbrli:unit id="USD">
    <xbrli:measure>iso4217:USD</xbrli:measure>
  </xbrli:unit>
  <xbrli:unit id="GBP">
    <xbrli:measure>iso4217:GBP</xbrli:measure>
  </xbrli:unit>
  <!-- unused, so doesn't appear in the output -->
  <xbrli:unit id="FRF">
    <xbrli:measure>iso4217:FRF</xbrli:measure>
  </xbrli:unit>
  <rend:m1 id="m1_EUR" contextRef="context" decimals="0" unitRef="EUR">101</rend:m1>
  <rend:m2 id="m2_EUR" contextRef="context" decimals="0" unitRef="EUR">102</rend:m2>
  <rend:m1 id="m1_USD" contextRef="context" decimals="0" unitRef="USD">133</rend:m1>
  <rend:m2 id="m2_USD" contextRef="context" decimals="0" unitRef="USD">135</rend:m2>
  <rend:m1 id="m1_GBP" contextRef="context" decimals="0" unitRef="GBP">85</rend:m1>
  <rend:m2 id="m2_GBP" contextRef="context" decimals="0" unitRef="GBP">86</rend:m2>
</xbrli:xbrl>