<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:iso4217="http://www.xbrl.org/2003/iso4217" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Aspect node for unit</label>
    <table>
      <headers axis="y">
        <group>
          <label>Two rows (primary items m1, m2)</label>
          <header>
            <cell>
              <label>Label: m1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: m2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:m2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Columns (reported units)</label>
          <header>
            <cell>
              <constraint>
                <aspect>unit</aspect>
                <value>
                  <xbrli:unit>
                    <xbrli:measure>iso4217:EUR</xbrli:measure>
                  </xbrli:unit>
                </value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>unit</aspect>
                <value>
                  <xbrli:unit>
                    <xbrli:measure>iso4217:USD</xbrli:measure>
                  </xbrli:unit>
                </value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>unit</aspect>
                <value>
                  <xbrli:unit>
                    <xbrli:measure>iso4217:GBP</xbrli:measure>
                  </xbrli:unit>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>unit-aspect-node-instance.xml#m1_EUR</fact>
            </cell>
            <cell>
              <fact>unit-aspect-node-instance.xml#m1_USD</fact>
            </cell>
            <cell>
              <fact>unit-aspect-node-instance.xml#m1_GBP</fact>
            </cell>
          </cells>
          <cells axis="x">
            <cell>
              <fact>unit-aspect-node-instance.xml#m2_EUR</fact>
            </cell>
            <cell>
              <fact>unit-aspect-node-instance.xml#m2_USD</fact>
            </cell>
            <cell>
              <fact>unit-aspect-node-instance.xml#m2_GBP</fact>
            </cell>
          </cells>
        </cells>
      </cells>
    </table>
  </tableSet>
</tableModel>