<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label" 
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:pf="http://xbrl.org/2008/filter/period"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xfi="http://www.xbrl.org/2008/function/instance"
               xsi:schemaLocation="             
			   http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
			   http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
			   http://xbrl.org/2008/reference http://www.xbrl.org/2008/generic-reference.xsd
			   http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
			   http://xbrl.org/2008/filter/period http://www.xbrl.org/2008/period-filter.xsd
			   http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/table5" xlink:type="simple" xlink:href="table-examples-roles.xsd#table5"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
   <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/aspect-node-filter" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#aspect-node-filter"/>
   <link:roleRef roleURI="http://www.xbrl.org/table-examples/coordinate-code" xlink:type="simple" xlink:href="table-examples-roles.xsd#coordinate-code"/>
   <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
   <link:roleRef roleURI="http://www.xbrl.org/2010/role/message"  xlink:type="simple" xlink:href="http://www.xbrl.org/2010/generic-message.xsd#standard-message"/>

   <gen:link xlink:type="extended"
             xlink:role="http://www.xbrl.org/table-examples/table5">
      <table:table xlink:type="resource" xlink:label="table5"
                   id="table5"/>
      <label:label xlink:type="resource" xlink:label="label_table51"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table51">Aspect node for a typed dimension with a forever filter</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5"
               xlink:to="label_table51"/>

      <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table5-x1" id="table5-x1"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="x"
                          xlink:from="table5"
                          xlink:to="table5-x1"
                          order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-x1">Three columns (primary items m1, m2, o1)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1"
               xlink:to="label_table5-x1"/>

      <table:ruleNode xlink:type="resource" xlink:label="table5-x1.1" id="table5-x1.1" abstract="true">
         <formula:period>
            <formula:instant value="xs:date('2000-12-31')"/>
         </formula:period>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table5-x1"
               xlink:to="table5-x1.1"
               order="1"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-x1.11">Label: Start of 2001</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.1"
               xlink:to="label_table5-x1.11"/>

      <table:ruleNode xlink:type="resource" xlink:label="table5-x1.1.1" id="table5-x1.1.1">
         <formula:concept>
            <formula:qname>rend:m1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:definitionNodeSubtreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/definition-node-subtree"
               xlink:from="table5-x1.1"
               xlink:to="table5-x1.1.1"
               order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.1.11"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-x1.1.11">Label: m1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.1.1"
               xlink:to="label_table5-x1.1.11"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.1.12"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table5-x1.1.12">1</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.1.1"
               xlink:to="label_table5-x1.1.12"/>
      <table:ruleNode xlink:type="resource" xlink:label="table5-x1.1.2" id="table5-x1.1.2">
         <formula:concept>
            <formula:qname>rend:m2</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:definitionNodeSubtreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/definition-node-subtree"
               xlink:from="table5-x1.1"
               xlink:to="table5-x1.1.2"
               order="4"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.1.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-x1.1.21">Label: m2</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.1.2"
               xlink:to="label_table5-x1.1.21"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.1.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table5-x1.1.22">2</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.1.2"
               xlink:to="label_table5-x1.1.22"/>

      <table:ruleNode xlink:type="resource" xlink:label="table5-x1.2" id="table5-x1.2">
         <formula:period>
            <formula:forever/>
         </formula:period>
         <formula:concept>
            <formula:qname>rend:o1</formula:qname>
         </formula:concept>
      </table:ruleNode>
      <table:breakdownTreeArc xlink:type="arc"
               xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
               xlink:from="table5-x1"
               xlink:to="table5-x1.2"
               order="2"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.21"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-x1.21">Label: o1</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.2"
               xlink:to="label_table5-x1.21"/>
      <label:label xlink:type="resource" xlink:label="label_table5-x1.22"
                   xlink:role="http://www.xbrl.org/table-examples/coordinate-code"
                   xml:lang="en"
                   id="label_table5-x1.22">3</label:label>
      <gen:arc order="2" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-x1.2"
               xlink:to="label_table5-x1.22"/>


      <table:breakdown xlink:type="resource" xlink:label="table5-y" id="table5-y"/>
      <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown"
                          axis="y"
                          xlink:from="table5"
                          xlink:to="table5-y"
                          order="6"/>
      <label:label xlink:type="resource" xlink:label="label_table5-y"
                   xlink:role="http://www.xbrl.org/2008/role/label"
                   xml:lang="en"
                   id="label_table5-y">Rows (typed dimension T)</label:label>
      <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table5-y"
               xlink:to="label_table5-y"/>
      <table:aspectNode xlink:type="resource" xlink:label="table5-y.1" id="table5-y.1">
        <table:dimensionAspect>rend:T</table:dimensionAspect>
      </table:aspectNode>
      <pf:forever xlink:type="resource" xlink:label="filter_table5-y.1" id="filter_table5-y.1"/>
      <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree"
                          xlink:from="table5-y"
                          xlink:to="table5-y.1"/>
      <table:aspectNodeFilterArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/aspect-node-filter"
                          xlink:from="table5-y.1"
                          xlink:to="filter_table5-y.1"/>
   </gen:link>

</link:linkbase>