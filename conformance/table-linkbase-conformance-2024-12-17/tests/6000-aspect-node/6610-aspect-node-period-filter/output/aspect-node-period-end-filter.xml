              <label>Label: First Half</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2001-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2001-07-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
            <cell span="2">
              <label>Label: Second Half</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2001-07-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2002-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
        <group>
          <label>Two columns (primary items o1, o2)</label>
          <header>
            <cell>
              <label>Label: o1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o2</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o1</label>
              <label>1</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o1</value>
              </constraint>
            </cell>
            <cell>
              <label>Label: o2</label>
              <label>2</label>
              <constraint>
                <aspect>concept</aspect>
                <value>rend:o2</value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <cells axis="z">
        <cells axis="y">
          <cells axis="x">
            <cell>
              <fact>aspect-node-period-end-filter-instance.xml#o1_Y2001_T_abc</fact>
