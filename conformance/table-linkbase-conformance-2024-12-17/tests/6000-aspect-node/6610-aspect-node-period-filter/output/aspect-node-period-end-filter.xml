<?xml version='1.0' encoding='utf-8'?>
<tableModel xmlns="http://xbrl.org/2014/table/model" xmlns:xbrli="http://www.xbrl.org/2003/instance" xmlns:rend="http://www.xbrl.org/table-examples" xml:base="..">
  <tableSet>
    <label>Aspect node for a typed dimension with an period-end filter</label>
    <table>
      <headers axis="y">
        <group>
          <label>Rows (typed dimension T)</label>
          <header>
            <cell>
              <constraint>
                <aspect>rend:T</aspect>
                <value>
                  <rend:stringDomain>abc</rend:stringDomain>
                </value>
              </constraint>
            </cell>
            <cell>
              <constraint>
                <aspect>rend:T</aspect>
                <value>
                  <rend:stringDomain>def</rend:stringDomain>
                </value>
              </constraint>
            </cell>
          </header>
        </group>
      </headers>
      <headers axis="x">
        <group>
          <label>Three columns (periods 2001, 2001H1, 2001H2)</label>
          <header>
            <cell span="6">
              <label>Label: 2001</label>
              <constraint>
                <aspect>period</aspect>
                <value>
                  <xbrli:startDate>2001-01-01T00:00:00Z</xbrli:startDate>
                  <xbrli:endDate>2002-01-01T00:00:00Z</xbrli:endDate>
                </value>
              </constraint>
            </cell>
          </header>
          <header>
            <cell span="2" rollup="true"/>
