<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase xmlns:label="http://xbrl.org/2008/label"
               xmlns:gen="http://xbrl.org/2008/generic"
               xmlns:xlink="http://www.w3.org/1999/xlink"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:link="http://www.xbrl.org/2003/linkbase"
               xmlns:table="http://xbrl.org/2014/table"
               xmlns:formula="http://xbrl.org/2008/formula"
               xmlns:variable="http://xbrl.org/2008/variable"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xfi="http://www.xbrl.org/2008/function/instance"
               xmlns:rend="http://www.xbrl.org/table-examples"
               xsi:schemaLocation="             
                 http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd
                 http://xbrl.org/2008/generic http://www.xbrl.org/2008/generic-link.xsd
                 http://xbrl.org/2008/label http://www.xbrl.org/2008/generic-label.xsd
                 http://xbrl.org/2008/variable http://www.xbrl.org/2008/variable.xsd
                 http://xbrl.org/2014/table http://www.xbrl.org/2014/table.xsd
               ">
    <link:roleRef roleURI="http://www.xbrl.org/table-examples/table3" xlink:type="simple" xlink:href="table-examples-roles.xsd#table3"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2008/element-label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#element-label"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-breakdown" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-breakdown"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#breakdown-tree"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/definition-node-subtree" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#definition-node-subtree"/>
    <link:arcroleRef arcroleURI="http://xbrl.org/arcrole/2014/table-parameter" xlink:type="simple" xlink:href="http://www.xbrl.org/2014/table.xsd#table-parameter"/>
    <link:roleRef roleURI="http://www.xbrl.org/2008/role/label" xlink:type="simple" xlink:href="http://www.xbrl.org/2008/generic-label.xsd#standard-label"/>
                 
    <gen:link xlink:type="extended" xlink:role="http://www.xbrl.org/table-examples/table3">

        <!-- parameter finds link roles used on domain-member relationships -->
        <variable:parameter xlink:type="resource" xlink:label="linkrole_param" name="linkroles" select="
          xfi:linkbase-link-roles('http://xbrl.org/int/dim/arcrole/domain-member')[matches(., 'dimension-domains')]
        "/>

        <table:table xlink:type="resource" xlink:label="table3" id="table3"/>
        <label:label xlink:type="resource" xlink:label="label_table3" xlink:role="http://www.xbrl.org/2008/role/label" id="label_table3" xml:lang="en">Dimension relationship node with parameterized link role</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table3" xlink:to="label_table3"/>
        
        <!-- bind link role to $linkrole for each table -->
        <table:tableParameterArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-parameter" xlink:from="table3" xlink:to="linkrole_param" name="linkrole"/>

        <!-- Declare X axis -->
        <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table3-x" id="table3-x"/>
        <!-- Connect table to X axis -->
        <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="x" xlink:from="table3" xlink:to="table3-x"/>
        <!-- Create appropriate label for first breakdown on X axis -->
        <label:label xlink:type="resource" xlink:label="label_table3-x"
                     xlink:role="http://www.xbrl.org/2008/role/label"
                     xml:lang="en"
                     id="label_table3-x">Two columns (primary items m1, m2)</label:label>
        <!-- Connect label to X axis content -->
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
               xlink:from="table3-x"
               xlink:to="label_table3-x"/>

        <!-- Find content for first column header on X axis by stating the concept -->
        <table:ruleNode xlink:type="resource" xlink:label="table3-x.1" id="table3-x.1">
           <formula:concept>
                <formula:qname>rend:m1</formula:qname>
            </formula:concept>
        </table:ruleNode>
        <!-- Connect X axis content to X axis -->
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table3-x" xlink:to="table3-x.1" order="1"/>
        <!-- Create appropriate label for first column on X axis -->
        <label:label xlink:type="resource" xlink:label="label_table3-x.11" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en" id="label_table3-x.11">Label: m1</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table3-x.1" xlink:to="label_table3-x.11"/>

        <!-- Find content for second column header on X axis by stating the concept -->
        <table:ruleNode xlink:type="resource" xlink:label="table3-x.2" id="table3-x.2">
            <formula:concept>
                <formula:qname>rend:m2</formula:qname>
            </formula:concept>
        </table:ruleNode>
        <!-- Connect X axis content to X axis -->
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table3-x" xlink:to="table3-x.2" order="2"/>
        <!-- Create appropriate label for second column on X axis -->
        <label:label xlink:type="resource" xlink:label="label_table3-x.21" xlink:role="http://www.xbrl.org/2008/role/label" xml:lang="en" id="label_table3-x.21">Label: m2</label:label>
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label" xlink:from="table3-x.2" xlink:to="label_table3-x.21"/>

        <!-- Declare Y axis, for the Dimension Linkbase, has a name which is bound like a variable so it can be used to specify label -->
        <table:breakdown parentChildOrder="parent-first" xlink:type="resource" xlink:label="table3-y" id="table3-y"/>
        <!-- Connect table to Y axis -->
        <table:tableBreakdownArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/table-breakdown" axis="y" xlink:from="table3" xlink:to="table3-y"/>
        <!-- Create appropriate label for first breakdown on Y axis -->
        <label:label xlink:type="resource" xlink:label="label_table3-y"
                     xlink:role="http://www.xbrl.org/2008/role/label"
                     xml:lang="en"
                     id="label_table3-y">Domain-member tree for dimension F</label:label>
        <!-- Connect label to Y axis content -->
        <gen:arc order="1" xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2008/element-label"
                 xlink:from="table3-y"
                 xlink:to="label_table3-y"/>

        <!-- Find content for Y axis by following a DRS tree -->
        <table:dimensionRelationshipNode xlink:type="resource" xlink:label="table3-y.1" id="table3-y.1">
            <!-- rend:F occurs in multiple link roles with different domains -->
            <table:relationshipSource>rend:f0</table:relationshipSource>
            <table:linkroleExpression>$linkrole</table:linkroleExpression>
            <table:dimension>rend:F</table:dimension>
        </table:dimensionRelationshipNode>
        <!-- Connect Y axis content to Y axis -->
        <table:breakdownTreeArc xlink:type="arc" xlink:arcrole="http://xbrl.org/arcrole/2014/breakdown-tree" xlink:from="table3-y" xlink:to="table3-y.1" order="1"/>

    </gen:link>

</link:linkbase>             