<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal English label linkbase for the BDE sample taxonomy unit test stub.
-->
<link:linkbase
  xmlns:link="http://www.xbrl.org/2003/linkbase"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd">

  <link:labelLink xlink:type="extended" xlink:role="http://www.xbrl.org/2003/role/link">

    <link:loc xlink:type="locator" xlink:href="entry_point.xsd#test_Assets" xlink:label="test_Assets"/>
    <link:label xlink:type="resource" xlink:label="test_Assets_label"
                xlink:role="http://www.xbrl.org/2003/role/label"
                xml:lang="en">Assets</link:label>
    <link:labelArc xlink:type="arc"
                   xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label"
                   xlink:from="test_Assets" xlink:to="test_Assets_label" order="1"/>

    <link:loc xlink:type="locator" xlink:href="entry_point.xsd#test_EntityName" xlink:label="test_EntityName"/>
    <link:label xlink:type="resource" xlink:label="test_EntityName_label"
                xlink:role="http://www.xbrl.org/2003/role/label"
                xml:lang="en">Entity Name</link:label>
    <link:labelArc xlink:type="arc"
                   xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label"
                   xlink:from="test_EntityName" xlink:to="test_EntityName_label" order="1"/>

  </link:labelLink>

</link:linkbase>
